<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer soft glow -->
    <item>
        <shape android:shape="rectangle">
            <stroke android:width="20dp" android:color="#338B5CF6" />
        </shape>
    </item>
    <!-- Middle glow -->
    <item android:left="4dp" android:top="4dp" android:right="4dp" android:bottom="4dp">
        <shape android:shape="rectangle">
            <stroke android:width="10dp" android:color="#808B5CF6" />
        </shape>
    </item>
    <!-- Inner solid edge -->
    <item android:left="10dp" android:top="10dp" android:right="10dp" android:bottom="10dp">
        <shape android:shape="rectangle">
            <stroke android:width="4dp" android:color="#8B5CF6" />
        </shape>
    </item>
</layer-list>